<% layout("/layouts/boilerplate") %>
<body>
    <h3>All Lists</h3>
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1">
        <% for(let list of allListings) { %>
            <a href="/listings/<%=list._id%>" class="listing-link">
                <div class="card col">
                    <img src="<%= list.image.url %>" class="card-img-top" style="height: 20rem;" alt="Listing_img"/>
                    <div class="card-img-overlay"></div>
                    <div class="card-body">
                      <p class="card-text">
                        <b><%= list.title %> <br/></b>
                        &#8377; <%= list.price ? list.price.toLocaleString("en-IN") : "N/A" %> / night  
                      </p>
                    </div>
                </div>
            </a>
        <% } %>
    </div>
</body>